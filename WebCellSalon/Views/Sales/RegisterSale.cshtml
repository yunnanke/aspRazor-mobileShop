@model RegisterSaleViewModel
@{
    ViewData["Title"] = "Оформление продажи";
}

<h1 class="page-title">Оформление продажи</h1>
<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ClientId" class="form-label"></label>
                    <select asp-for="ClientId" asp-items="Model.ClientOptions" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="PaymentMethodId" class="form-label"></label>
                    <select asp-for="PaymentMethodId" asp-items="Model.PaymentMethodOptions" class="form-select"></select>
                </div>
                <div class="col-12">
                    <label asp-for="SerialNumbers" class="form-label"></label>
                    <textarea asp-for="SerialNumbers" class="form-control" rows="4" placeholder="Введите серийные номера через запятую"></textarea>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Зарегистрировать продажу</button>
                </div>
            </div>
        </form>
    </div>
</div>
