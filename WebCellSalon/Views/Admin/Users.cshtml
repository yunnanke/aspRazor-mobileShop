    <div class="col-xl-7">
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Логин</th>
                            <th>Роль</th>
                            <th>Владелец</th>
                            <th>Активна</th>
                            <th>Последний вход</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Accounts)
                        {
                            <tr>
                                <td>@item.AccountId</td>
                                <td>@item.Login</td>
                                <td>@item.Role</td>
                                <td>@item.OwnerName</td>
                                <td>@(item.IsActive ? "Да" : "Нет")</td>
                                <td>@item.LastLoginAt?.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-end">
                                    <form method="post" action="/Admin/Users/ToggleActive/@item.AccountId" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Блок/разблок</button>
                                    </form>
                                    <form method="post" action="/Admin/Users/ResetPassword/@item.AccountId" class="d-inline-flex gap-2">
                                        @Html.AntiForgeryToken()
                                        <input name="newPassword" class="form-control form-control-sm" placeholder="Новый пароль" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Сброс</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
