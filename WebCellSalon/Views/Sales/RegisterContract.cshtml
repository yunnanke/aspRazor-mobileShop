@model RegisterContractViewModel
@{
    ViewData["Title"] = "Договор + SIM";
}

<h1 class="page-title">Оформление договора с SIM</h1>
<div class="card shadow-sm">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ClientId" class="form-label"></label>
                    <select asp-for="ClientId" asp-items="Model.ClientOptions" class="form-select"></select>
                </div>
                <div class="col-md-6">
                    <label asp-for="ContractType" class="form-label"></label>
                    <input asp-for="ContractType" class="form-control" />
                </div>
                <div class="col-12">
                    <label asp-for="SimIccid" class="form-label"></label>
                    <input asp-for="SimIccid" class="form-control" />
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Оформить договор</button>
                </div>
            </div>
        </form>
    </div>
</div>
