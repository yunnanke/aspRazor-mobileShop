@model List<Employee>
@{
    ViewData["Title"] = "Сотрудники";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="page-title mb-0">Сотрудники</h1>
    <a href="/Employees/Create" class="btn btn-primary">Добавить сотрудника</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>ФИО</th>
                    <th>Телефон</th>
                    <th>Email</th>
                    <th>Должность ID</th>
                    <th>Дата приёма</th>
                    <th>Зарплата</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.FullName</td>
                        <td>@item.Phone</td>
                        <td>@item.Email</td>
                        <td>@item.PositionId</td>
                        <td>@item.HireDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.Salary.ToString("N2") ₽</td>
                        <td class="text-end">
                            <a href="/Employees/Edit/@item.Id" class="btn btn-sm btn-outline-primary">Изменить</a>
                            <form method="post" action="/Employees/Delete/@item.Id" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
